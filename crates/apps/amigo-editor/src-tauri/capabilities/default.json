{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the Amigo Editor startup shell.",
  "windows": ["main", "startup", "workspace-*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-is-fullscreen",
    "core:window:allow-set-fullscreen"
  ]
}
