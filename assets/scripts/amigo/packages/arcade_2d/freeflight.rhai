fn drive_freeflight(world, entity, thrust_action, turn_action) {
    world.arcade.drive_freeflight(entity, thrust_action, turn_action)
}

fn drive_freeflight_with_emitter(world, entity, emitter, thrust_action, turn_action) {
    world.arcade.drive_freeflight_with_emitter(entity, emitter, thrust_action, turn_action)
}
